# Copy to .env and fill in your values

OPENROUTER_API_KEY=your_openrouter_key_here

# SendGrid (Twilio) — https://app.sendgrid.com
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
DEFAULT_FROM_EMAIL=adubeasarah44@gmail.com
SITE_NAME=Testa StudyBuddy
SITE_URL=http://127.0.0.1:8000
SUPPORT_EMAIL=adubeasarah44@gmail.com

# Google Search Console — HTML tag verification (content value only)
# GOOGLE_SITE_VERIFICATION=your_verification_code_here

# Database: sqlite (local dev) | postgresql (production / Supabase)
DB_ENGINE=postgresql

# Option 1 — Supabase (recommended for hosted Postgres)
# Dashboard: Project Settings → Database → Connection string → URI
# Use "Session" mode (port 5432) for migrations; "Transaction" pooler (6543) for high traffic
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# Option 2 — Local PostgreSQL (if not using DATABASE_URL)
POSTGRES_DB=testa_studybuddy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# POSTGRES_SSLMODE=prefer
